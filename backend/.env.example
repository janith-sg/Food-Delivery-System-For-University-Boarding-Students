# Copy this file to .env and fill in your MongoDB Atlas (or local) URI.
# Never commit .env — it is listed in .gitignore.

# MongoDB connection string (include database name before ?)
# Example Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/uni_eats?retryWrites=true&w=majority

MONGODB_URI=
PORT=3000
