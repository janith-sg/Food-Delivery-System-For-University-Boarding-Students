# Copy this file to .env and fill in your MongoDB Atlas (or local) URI.
# Never commit .env — it is listed in .gitignore.

# MongoDB connection string (include database name before ?)
# Example Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/uni_eats?retryWrites=true&w=majority

#MONGODB_URI=
#PORT=3000

# JWT for admin login (use a long random string in production)
#JWT_SECRET=change_me_to_a_long_random_string
#JWT_EXPIRES_IN=7d

# Fixed admin user (created once on first server start if no user with this email exists)
#ADMIN_EMAIL=admin@uni-eats.local
#ADMIN_PASSWORD=ChangeThisPassword123
#ADMIN_NAME=System Admin
#ADMIN_PHONE=0000000000

# SMTP (for forgot-password emails)
# Example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="UNI EATS <your_email@gmail.com>"
# SMTP_HOST=
#SMTP_PORT=
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=
